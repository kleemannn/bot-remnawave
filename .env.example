NODE_ENV=production
PORT=3000
APP_VERSION=1.0.0
APP_LOG_LEVEL=log
WEBAPP_JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET
WEBAPP_JWT_TTL_SEC=43200
WEBAPP_INIT_DATA_TTL_SEC=3600
WEBAPP_ALLOWED_ORIGINS=https://miniapp.example.com
MINIAPP_GATEWAY_BIND_PORT=3012

DATABASE_URL=postgresql://remna_user:remna_pass@postgres:5432/remna_bot?schema=public

TELEGRAM_BOT_TOKEN=1234567890:REPLACE_WITH_TELEGRAM_BOT_TOKEN
ADMIN_TELEGRAM_IDS=123456789
BOT_RATE_LIMIT_WINDOW_MS=10000
BOT_RATE_LIMIT_MAX_TEXTS=12
BOT_RATE_LIMIT_MAX_CALLBACKS=24
BOT_RATE_LIMIT_MAX_COMMANDS=12
BOT_EXPENSIVE_ACTION_COOLDOWN_MS=3000

REMNAWAVE_API_BASE_URL=https://your-remnawave-panel.example.com/api
REMNAWAVE_API_TOKEN=REPLACE_WITH_REMNAWAVE_API_TOKEN
REMNAWAVE_TIMEOUT_MS=10000
REMNAWAVE_RETRY_COUNT=1
REMNAWAVE_RETRY_DELAY_MS=500
HAPP_CRYPTO_API_URL=https://crypto.happ.su/api-v2.php
HAPP_CRYPTO_TIMEOUT_MS=10000
HEALTHCHECK_DB_TIMEOUT_MS=3000

STANDARD_SQUAD_ID=00000000-0000-0000-0000-000000000001
PREMIUM_SQUAD_ID=00000000-0000-0000-0000-000000000002
